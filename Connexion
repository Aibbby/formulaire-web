    # =========================
    # VALIDATIONS
    # =========================
    def valider_pan(self, valeur):
        if valeur == "":
            return True
        return valeur.isdigit() and len(valeur) <= 16

    def valider_date_val(self, valeur):
        if valeur == "":
            return True

        if any(c not in "0123456789/" for c in valeur):
            return False

        if len(valeur) == 2 and "/" not in valeur:
            self.entry_date_val.after(1, lambda: self.entry_date_val.insert(tk.END, "/"))
            return True

        if len(valeur) > 5:
            return False

        if "/" in valeur:
            if valeur.count("/") > 1:
                return False
            if valeur.index("/") != 2:
                return False

        return True

