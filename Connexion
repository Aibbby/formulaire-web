    def client_tcp(self):
        host, port = self.get_host_port_selectionnes()
        self.ecrire_console(f"Connexion au serveur : {host}:{port}...")

        try:
            self.client_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.client_socket.settimeout(60.0)
            self.client_socket.connect((host, port))

            self.root.after(0, lambda: self.bouton_envoyer_0100.config(state="normal"))
            self.ecrire_console(f"Connecté de manière stable à {host}:{port}. Le bouton d'envoi 0100 est activé.")

            compteur_0800 = 0

            while True:
                try:
                    data_rx = self.client_socket.recv(4096)

                    if not data_rx:
                        self.ecrire_console("Le serveur distant a clos la connexion socket.")
                        break

                    hexa_recu = data_rx.hex().upper()

                    if "160102" in hexa_recu:
                        idx_sync = hexa_recu.index("160102")
                        if idx_sync >= 8:
                            hexa_recu = hexa_recu[idx_sync - 8:]
                        else:
                            hexa_recu = hexa_recu[idx_sync:]
                    else:
                        self.ecrire_console("Message reçu non conforme (Pas de '160102' détecté).")
                        continue

                    if "0800" in hexa_recu:
                        compteur_0800 += 1
                        self.ecrire_console(f"--- message ISO 0800 Reçu (N°{compteur_0800}) ---\nRx (Brut) : {hexa_recu}")

                        champ7_recu = hexa_recu[88:98] if len(hexa_recu) >= 98 else "0715091638"
                        champ11_recu = hexa_recu[98:104] if len(hexa_recu) >= 104 else "000018"
                        champ70_recu = hexa_recu.strip()[-4:]
                        if not champ70_recu or len(champ70_recu) != 4:
                            champ70_recu = "0071"

                        self.ecrire_console(
                            f"Champs extraits de la 0800 -> Date: {champ7_recu} | STAN: {champ11_recu} | Mgt Code: {champ70_recu}"
                        )

                        self.ecrire_console("En attente de 1 seconde avant de répondre (0810)...")
                        time.sleep(1.0)

                        reponse_0810 = self.generer_reponse_0810_strict(champ7_recu, champ11_recu, champ70_recu)
                        self.client_socket.sendall(bytes.fromhex(reponse_0810))
                        self.ecrire_console(f"Réponse 0810 (N°{compteur_0800}) émise.")

                    elif "0110" in hexa_recu:
                        self.ecrire_console("=" * 85)
                        self.ecrire_console("◄── RÉCEPTION RÉPONSE D'AUTORISATION (Rx) - MTI 0110")
                        self.ecrire_console(f"Rx Brut (0110) : {hexa_recu}")

                        self.root.after(0, lambda: self.bouton_envoyer_0100.config(state="normal"))

                        if "F0F0" in hexa_recu:
                            self.ecrire_console("  • Statut de la transaction : APPROUVÉ (Code 39 = '00')")
                        elif "F0F5" in hexa_recu:
                            self.ecrire_console("  • Statut de la transaction : REJETÉ (Code 39 = '05')")
                        else:
                            self.ecrire_console("  • Statut de la transaction : Traité")
                        self.ecrire_console("=" * 85)

                    else:
                        self.ecrire_console(f"Message reçu et non traité : {hexa_recu}")

                except socket.timeout:
                    self.ecrire_console("Aucune activité réseau depuis 60s (Écoute toujours active)...")
                    continue

        except Exception as e:
            self.ecrire_console(f"Erreur réseau : {str(e)}")

        self.client_socket = None
        self.root.after(0, lambda: self.bouton_envoyer_0100.config(state="disabled"))
        self.ecrire_console("Session TCP/IP terminée.")
        self.root.after(0, lambda: self.bouton_connexion.config(state="normal"))


