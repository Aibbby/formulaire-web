    def on_check_pnr(self):
        if self.var_pnr.get():
            self.var_pnh.set(False)
            self.ecrire_console("Environnement sélectionné : PNR -> Hôte NXLRASM011, Port 22201")
        else:
            if not self.var_pnh.get():
                self.var_pnh.set(True)

    def on_check_pnh(self):
        if self.var_pnh.get():
            self.var_pnr.set(False)
            self.ecrire_console("Environnement sélectionné : PNH -> Hôte NXLIASM012, Port 22201")
        else:
            if not self.var_pnr.get():
                self.var_pnr.set(True)

    def get_host_port_selectionnes(self):
        if self.var_pnr.get():
            return "NXLRASM011", 22201
        return "NXLIASM012", 22201

